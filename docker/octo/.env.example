# -----------------------------------------------------------------------------
# OCTO Server · docker/octo stack environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your deployment:
#
#     cp docker/octo/.env.example docker/octo/.env
#
# At minimum you MUST change:
#   - MYSQL_ROOT_PASSWORD
#   - MINIO_ROOT_PASSWORD
#   - OCTO_MASTER_KEY  (generate with `openssl rand -hex 16`)
#
# Everything else has sane defaults for a single-host dev deployment.
# -----------------------------------------------------------------------------

# --- Domain & host --------------------------------------------------------
# The hostname nginx will serve. Add an entry like
#   127.0.0.1 octo.local
# to /etc/hosts on the machine where you will browse the stack from.
OCTO_DOMAIN=octo.local
# External IP/hostname that WuKongIM will advertise to mobile/web clients.
# Use your LAN IP if you want to connect from other devices.
OCTO_EXTERNAL_IP=127.0.0.1

# --- Port mapping (host side) ---------------------------------------------
# Chosen to avoid collisions with typical local services.
OCTO_HTTP_PORT=28080
OCTO_HTTPS_PORT=28443
OCTO_SERVER_PORT=28081
OCTO_ADMIN_PORT=28082
OCTO_WEB_PORT=28083
OCTO_MATTER_PORT=28086
OCTO_SUMMARY_API_PORT=28087
OCTO_WK_API_PORT=25001
OCTO_WK_TCP_PORT=25100
OCTO_WK_WS_PORT=25200
OCTO_WK_MONITOR_PORT=25300
OCTO_MYSQL_PORT=23306
OCTO_REDIS_PORT=26379
OCTO_MINIO_API_PORT=29000
OCTO_MINIO_CONSOLE_PORT=29001

# --- Docker network -------------------------------------------------------
# Dedicated subnet so the stack does not clash with other bridge networks.
OCTO_NETWORK_SUBNET=172.28.0.0/16

# --- Timezone -------------------------------------------------------------
TZ=UTC

# --- MySQL ----------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=octo

# --- Redis ----------------------------------------------------------------
# (no required settings — redis is unauthenticated on the internal network)

# --- MinIO (S3-compatible object storage) ---------------------------------
MINIO_ROOT_USER=octoadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_SERVER_URL=http://localhost:29000
MINIO_BROWSER_REDIRECT_URL=http://localhost:29001

# --- WuKongIM -------------------------------------------------------------
# debug | release | bench
WK_MODE=debug

# How WuKongIM advertises its public endpoints when web/mobile clients call
# GET /route on login. Defaults route through the bundled nginx on
# ${OCTO_DOMAIN}:${OCTO_HTTP_PORT}/ws, which is the endpoint the quickstart
# stack actually exposes. In production behind an outer TLS terminator,
# override OCTO_WK_WSS_ADDR to the canonical wss:// URL.
#
# Examples:
#   Local dev (default) :  OCTO_WK_WS_ADDR=ws://octo.local:28080/ws
#   LAN IP              :  OCTO_WK_WS_ADDR=ws://192.168.1.42:28080/ws
#   TLS in prod         :  OCTO_WK_WSS_ADDR=wss://octo.example.com/ws
#                          (leave OCTO_WK_WS_ADDR blank)
OCTO_WK_WS_ADDR=ws://${OCTO_DOMAIN}:${OCTO_HTTP_PORT}/ws
OCTO_WK_WSS_ADDR=
OCTO_WK_TCP_ADDR=

# --- OCTO Server ----------------------------------------------------------
# Master key for at-rest encryption of user credentials (Bot tokens, OAuth
# secrets, etc.). MUST be exactly 32 bytes. Generate with:
#     openssl rand -hex 16
# Losing this key makes previously encrypted secrets unrecoverable.
OCTO_MASTER_KEY=CHANGE_ME_32_BYTES_octo_master_k

# Optional HMAC-SHA256 shared secret for inbound webhooks. Leave blank to
# disable signature verification (NOT recommended in production).
OCTO_WEBHOOK_SECRET_KEY=

# --- Side services: matter, smart-summary --------------------------------
# Shared secret (X-Internal-Token) that octo-matter / octo-smart-summary
# send when calling octo-server's internal /v1/internal/* endpoints.
# Generate with: openssl rand -hex 16
OCTO_NOTIFY_INTERNAL_TOKEN=CHANGE_ME_notify_internal_token

# Side-service MySQL passwords. Defaults reproduce the matter/summary/
# summary_reader values baked into earlier builds; override here if you
# want stronger credentials in a shared deployment. Must be set BEFORE
# the first `docker compose up` — they are baked into the MySQL users
# on first boot and not re-applied afterwards.
OCTO_MATTER_DB_PASSWORD=matter
OCTO_SUMMARY_DB_PASSWORD=summary
OCTO_SUMMARY_READER_PASSWORD=summary_reader

# URL of the smart-summary API as seen by octo-web. Leave blank to serve
# /summary/api/v1/* as 503 (i.e. disable the feature in the UI).
OCTO_SUMMARY_API_URL=http://summary-api:8080

# LLM used by octo-matter + octo-smart-summary. Leave blank to run the
# side services in "no-LLM" degraded mode; matter still CRUDs tasks, but
# summary generation will no-op.
LLM_API_URL=https://api.example.com/v1
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Optional image overrides. Default uses the GHCR latest tags that the OSS
# CI publishes. Set to a local tag (e.g. `octo-web:local`) if you are
# building the frontends yourself from their respective repos.
# OCTO_WEB_IMAGE=octo-web:local
# OCTO_ADMIN_IMAGE=octo-admin:local
# OCTO_MATTER_IMAGE=octo-matter:local
# OCTO_SUMMARY_API_IMAGE=octo-summary-api:local
# OCTO_SUMMARY_WORKER_IMAGE=octo-summary-worker:local
